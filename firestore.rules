rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check: role on the user doc. Do not grant admin by email alone.
    function isAdmin() {
      return isSignedIn() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Record ownership via the userId field used across all collections.
    function ownsResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function createsAsSelf() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Prevent reassigning a record to another user on update.
    function keepsOwner() {
      return request.resource.data.userId == resource.data.userId;
    }

    // ---------- users ----------
    // Docs are keyed by auth UID (see ensureUserExists in src/firebase.js).
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      // Users may create their own doc but never grant themselves admin.
      allow create: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.role != 'admin'
      );

      // Users may update their own doc but cannot change role or
      // assignments — only the admin manages those.
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.assignedProperties == resource.data.assignedProperties &&
        request.resource.data.get('assignedDeals', []) == resource.data.get('assignedDeals', [])
      );

      allow delete: if isAdmin();
    }

    // ---------- userId-scoped business collections ----------

    match /contacts/{docId} {
      allow read, delete: if isAdmin() || ownsResource();
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() || (ownsResource() && keepsOwner());
    }

    match /leads/{docId} {
      allow read, delete: if isAdmin() || ownsResource();
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() || (ownsResource() && keepsOwner());
    }

    match /deals/{docId} {
      // Buyers/sellers assigned to a deal (users/{uid}.assignedDeals) may
      // read it — the deal portal is shared with them, but never writable.
      function isAssignedToDeal() {
        return isSignedIn() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedDeals', []);
      }

      allow read: if isAdmin() || ownsResource() || isAssignedToDeal();
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() || (ownsResource() && keepsOwner());
      allow delete: if isAdmin() || ownsResource();
    }

    // ---------- deal portal collections ----------
    // All are keyed to a parent deal via a dealId field. Access follows the
    // parent deal: owner, admin, or an assigned portal participant.

    function canAccessDeal(dealId) {
      return isAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/deals/$(dealId)) &&
        (
          get(/databases/$(database)/documents/deals/$(dealId)).data.userId == request.auth.uid ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            dealId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedDeals', [])
          )
        )
      );
    }

    match /deal-parties/{docId} {
      allow read, update, delete: if canAccessDeal(resource.data.dealId);
      allow create: if canAccessDeal(request.resource.data.dealId);
    }

    match /deal-channels/{docId} {
      allow read, update, delete: if canAccessDeal(resource.data.dealId);
      allow create: if canAccessDeal(request.resource.data.dealId);
    }

    match /deal-messages/{docId} {
      allow read: if canAccessDeal(resource.data.dealId);
      allow create: if canAccessDeal(request.resource.data.dealId);
      // Messages are a record — no edits or deletes except by the admin.
      allow update, delete: if isAdmin();
    }

    match /deal-documents/{docId} {
      allow read, update, delete: if canAccessDeal(resource.data.dealId);
      allow create: if canAccessDeal(request.resource.data.dealId);
    }

    match /deal-progress/{docId} {
      allow read, update, delete: if canAccessDeal(resource.data.dealId);
      allow create: if canAccessDeal(request.resource.data.dealId);
    }

    match /deal-lender-pushes/{docId} {
      allow read: if canAccessDeal(resource.data.dealId);
      allow create: if canAccessDeal(request.resource.data.dealId);
      allow update, delete: if isAdmin();
    }

    match /properties/{docId} {
      // Assigned agents may read and update (but not delete) properties
      // assigned to them via users/{uid}.assignedProperties.
      function isAssignedToProperty() {
        return isSignedIn() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedProperties;
      }

      allow read: if isAdmin() || ownsResource() || isAssignedToProperty();
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() ||
        (ownsResource() && keepsOwner()) ||
        (isAssignedToProperty() && keepsOwner());
      allow delete: if isAdmin() || ownsResource();
    }

    match /documents/{docId} {
      allow read, delete: if isAdmin() || ownsResource();
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() || (ownsResource() && keepsOwner());
    }

    match /tasks/{docId} {
      // Tasks are visible to owner and assignee.
      allow read: if isAdmin() || ownsResource() ||
        (isSignedIn() && resource.data.assignedTo == request.auth.uid);
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() || (ownsResource() && keepsOwner()) ||
        (isSignedIn() && resource.data.assignedTo == request.auth.uid && keepsOwner());
      allow delete: if isAdmin() || ownsResource();
    }

    // ---------- campaigns ----------
    match /campaigns/{docId} {
      allow read, delete: if isAdmin() || ownsResource();
      allow create: if isAdmin() || createsAsSelf();
      allow update: if isAdmin() || (ownsResource() && keepsOwner());
    }

    // ---------- notifications ----------
    // Any signed-in user may create a notification but must stamp
    // themselves as the actor; only the recipient (or admin) can read,
    // mark read, or delete it.
    match /notifications/{docId} {
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      allow read, update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.recipientId == request.auth.uid);
    }

    // ---------- activity log ----------
    // Append-only audit trail. Nobody edits or deletes history — not even
    // the admin. Entries must be written as the acting user.
    match /activity_log/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ---------- companies ----------
    match /companies/{companyId} {
      allow read: if isAdmin() ||
        (isSignedIn() && request.auth.uid in resource.data.userIds);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---------- everything else ----------
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
